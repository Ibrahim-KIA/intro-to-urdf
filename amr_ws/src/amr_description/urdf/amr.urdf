<?xml version="1.0"?>
<robot name="amr">

    <!-- MATERIALS -->
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <!-- CHASSIS -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.5 0.3 0.1"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <!-- ================= WHEELS ================= -->

    <!-- FRONT LEFT WHEEL (Drive) -->
    <link name="wheel_front_left">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.04"/>
            </geometry>
            <material name="black"/>
        </visual>
    </link>

    <joint name="joint_wheel_front_left" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_front_left"/>
        <origin xyz="0.2 0.15 0" rpy="1.57 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- FRONT RIGHT WHEEL (Drive) -->
    <link name="wheel_front_right">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.04"/>
            </geometry>
            <material name="black"/>
        </visual>
    </link>

    <joint name="joint_wheel_front_right" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_front_right"/>
        <origin xyz="0.2 -0.15 0" rpy="1.57 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- REAR WHEELS -->
<link name="wheel_rear_left">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.04"/>
            </geometry>
            <material name="black"/>
        </visual>
    </link>

    <joint name="joint_wheel_rear_left" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_rear_left"/>
        <origin xyz="-0.2 0.15 0" rpy="1.57 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="wheel_rear_right">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.04"/>
            </geometry>
            <material name="black"/>
        </visual>
    </link>

    <joint name="joint_wheel_rear_right" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_rear_right"/>
        <origin xyz="-0.2 -0.15 0" rpy="1.57 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>